@startuml
title Mantener clasificación y correspondencias
skinparam shadowing false
start
:Seleccionar clasificación;
if (¿Nueva versión?) then (Sí)
  :Crear classification_version;
else (No)
  :Seleccionar versión editable;
endif
:Importar o registrar ítems jerárquicos;
:Validar códigos únicos y niveles;
:Definir correspondencias con otra versión;
:Clasificar equivalencia y ponderación;
if (¿Validación completa?) then (Sí)
  :Marcar versión vigente;
  :Cerrar vigencia de versión reemplazada;
else (No)
  :Mantener en borrador;
endif
stop
@enduml
