NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_NAME=observatorio-economico-core
API_PREFIX=api
API_VERSION=v1
CORS_ORIGINS=http://localhost:3001
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_CONNECTION_TIMEOUT_MS=10000
HTTP_KEEP_ALIVE_TIMEOUT_MS=72000
LOG_LEVEL=info
# Enable only when the direct peer is a trusted reverse proxy such as the included NGINX service.
TRUST_PROXY=true

# Use distinct least-privilege credentials even when both point to one PostgreSQL server.
DATABASE_WRITER_URL=postgresql://observatory_writer:change-me-writer@postgres:5432/observatorio_economico
DATABASE_READER_URL=postgresql://observatory_reader:change-me-reader@postgres:5432/observatorio_economico
DATABASE_MIGRATOR_URL=postgresql://observatory_migrator:change-me-migrator@postgres:5432/observatorio_economico
DATABASE_SSL=false
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_POOL_MAX_WRITER=15
DATABASE_POOL_MAX_READER=30
DATABASE_POOL_MIN=0
DATABASE_POOL_ACQUIRE_MS=15000
DATABASE_POOL_IDLE_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=15000

# Required only by the included local Docker Compose PostgreSQL bootstrap.
POSTGRES_ADMIN_PASSWORD=change-me-admin
MIGRATOR_PASSWORD=change-me-migrator
WRITER_PASSWORD=change-me-writer
READER_PASSWORD=change-me-reader
BACKUP_PASSWORD=change-me-backup

# disabled is accepted only outside production.
AUTH_MODE=disabled
AUTH_JWKS_URI=https://identity.example.test/.well-known/jwks.json
AUTH_ISSUER=https://identity.example.test/
AUTH_AUDIENCE=observatorio-economico-api
AUTH_ROLE_CLAIM=roles
AUTH_ORGANIZATION_CLAIM=organization_id

# Swagger is rejected by configuration validation in production.
SWAGGER_ENABLED=true
# NGINX blocks /metrics from the public edge; scrape it only from the internal application network.
METRICS_ENABLED=true

# Backup operations are invoked by an external scheduler or CI, never by the API process.
BACKUP_ENABLED=false
BACKUP_STRATEGY=pg_dump
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=/backups
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_COMPRESSION=custom
BACKUP_MAX_DURATION_SECONDS=3600
BACKUP_DATABASE_URL=postgresql://observatory_backup:change-me-backup@postgres:5432/observatorio_economico
