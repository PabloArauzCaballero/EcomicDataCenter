{
  "name": "observatorio-economico-core-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Core de datos del Observatorio Económico y de Mercados de Bolivia",
  "license": "UNLICENSED",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.19 <21 || >=22 <23"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0 --cache --cache-location artifacts/eslint/.cache",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "db:provision:roles": "tsx scripts/provision-remote-roles.ts",
    "db:grants:reapply": "tsx src/database/cli/reapply-runtime-grants.ts",
    "db:migrate": "tsx src/database/cli/migrate.ts",
    "db:migrate:undo": "tsx src/database/cli/migrate-undo.ts",
    "db:seed:boot": "tsx src/database/seeds/runners/run-boot-seeds.ts",
    "db:seed:mock": "tsx src/database/seeds/runners/run-mock-seeds.ts",
    "db:seed:verify": "tsx src/database/seeds/runners/verify-seed-idempotency.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "quality:files": "python scripts/check_file_limits.py",
    "quality:diagrams": "python scripts/validate_diagrams.py",
    "smoke": "tsx scripts/smoke.ts",
    "quality:syntax": "node --check eslint.config.mjs && node --check jest.config.cjs && node --check scripts/check_identifier_language.cjs && node --check scripts/check_typescript_syntax.cjs && node --check scripts/create-local-env.cjs && node --check scripts/verify-local-stack.cjs && node scripts/check_typescript_syntax.cjs",
    "quality:naming": "node scripts/check_identifier_language.cjs",
    "quality:project": "python scripts/validate_project.py",
    "quality:openapi": "python scripts/validate_openapi.py",
    "quality:all": "yarn quality:files && yarn quality:syntax && yarn quality:naming && yarn quality:imports && yarn quality:diagrams && yarn quality:clean-code && yarn quality:architecture && yarn quality:physical-model && yarn quality:seeds && yarn quality:persistence && yarn quality:use-cases && yarn quality:security && yarn quality:async-scope && yarn quality:operations && yarn quality:project && yarn quality:openapi && yarn quality:routes",
    "postman:generate": "python scripts/generate_postman.py",
    "quality:routes": "python scripts/validate_contract_routes.py",
    "quality:imports": "python scripts/validate_local_imports.py",
    "quality:architecture": "python scripts/validate_architecture.py",
    "quality:clean-code": "python scripts/check_clean_code.py",
    "quality:physical-model": "python scripts/validate_physical_model.py",
    "db:verify:privileges": "sh scripts/verify_database_privileges.sh",
    "db:verify:migrations": "tsx src/database/cli/verify-migration-cycle.ts",
    "db:seed:validate": "tsx src/database/seeds/runners/validate-seed-files.ts",
    "quality:seeds": "python scripts/validate_seed_catalogs.py",
    "quality:persistence": "python scripts/validate_persistence.py",
    "quality:use-cases": "python scripts/validate_use_cases.py",
    "quality:security": "python scripts/validate_security_contracts.py",
    "quality:async-scope": "python scripts/validate_async_scope.py",
    "quality:operations": "python scripts/validate_operations.py",
    "security:audit": "yarn audit --groups dependencies --level high",
    "compose:validate": "docker compose config --quiet",
    "local:env": "node scripts/create-local-env.cjs",
    "local:env:host": "node scripts/create-local-env.cjs --host",
    "local:up": "docker compose up --build -d",
    "local:seed:boot": "docker compose run --rm --no-deps api node dist/database/seeds/runners/run-boot-seeds.js",
    "local:seed:mock": "docker compose run --rm --no-deps api node dist/database/seeds/runners/run-mock-seeds.js",
    "local:seed": "yarn local:seed:boot && yarn local:seed:mock",
    "local:verify": "node scripts/verify-local-stack.cjs",
    "local:logs": "docker compose logs --tail=200 api migrate postgres nginx",
    "local:down": "docker compose down",
    "local:db:up": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d postgres",
    "local:db:down": "docker compose -f docker-compose.yml -f docker-compose.local.yml down",
    "release:verify": "sh scripts/run_release_verification.sh"
  },
  "dependencies": {
    "@fastify/helmet": "13.0.1",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "9.1.3",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/swagger": "11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "5.10.0",
    "jsonwebtoken": "9.0.2",
    "jwks-rsa": "3.2.0",
    "nestjs-pino": "4.6.1",
    "pg": "8.16.3",
    "pino": "9.9.5",
    "pino-http": "^11.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sequelize": "6.37.7",
    "sequelize-typescript": "2.1.6",
    "umzug": "3.8.2",
    "yaml": "2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "jest": "30.4.2",
    "prettier": "3.9.5",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0"
  }
}
