series ||--o{ series_break
methodology_version |o--o{ series_break

note bottom of series_dimension_value
CHECK: exactamente uno entre
code_item_id, classification_item_id,
geographic_unit_id, text_value,
numeric_value y date_value.
end note

note bottom of observation_measure
CHECK: exactamente uno entre
numeric_value, text_value y boolean_value.
end note

note bottom of observation_revision
Índice parcial recomendado:
UNIQUE(observation_id)
WHERE is_current = true.
end note
@enduml
